# Stripe — required for checkout
# Get these from https://dashboard.stripe.com/test/apikeys (use test keys first)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price ID — created by running: node stripe/setup.js
# Or create manually in Stripe Dashboard and paste the price ID here
STRIPE_PRICE_ID=price_...

# Add all three to Vercel:
#   vercel env add STRIPE_SECRET_KEY
#   vercel env add STRIPE_PUBLISHABLE_KEY
#   vercel env add STRIPE_PRICE_ID
